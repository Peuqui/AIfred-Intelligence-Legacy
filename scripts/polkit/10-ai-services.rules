// Polkit-Regel: AI-Service-Steuerung ohne sudo/Passwort
//
// Erlaubt den Usern 'mp' und 'www-data' die Steuerung (start/stop/restart/is-active)
// aller AI-bezogenen systemd-Services ohne Authentifizierung.
//
// Installation:
//   sudo cp scripts/polkit/10-ai-services.rules /etc/polkit-1/rules.d/
//   sudo chmod 644 /etc/polkit-1/rules.d/10-ai-services.rules
//
// Danach alte sudoers aufräumen:
//   sudo rm /etc/sudoers.d/ai-services
//   sudo rm /etc/sudoers.d/ai-connect

polkit.addRule(function(action, subject) {
    if (action.id === "org.freedesktop.systemd1.manage-units" &&
        (subject.user === "mp" || subject.user === "www-data")) {

        var unit = action.lookup("unit");
        var allowed = [
            "aifred-intelligence.service",
            "llama-swap.service",
            "ollama.service",
            "ai-connect.service",
            "ai-connect-mcp.service",
            "claude-api-wrapper.service",
            "haemotrace-backend.service",
            "haemotrace-reset-db.service",
            "haemotrace-build.service"
        ];

        for (var i = 0; i < allowed.length; i++) {
            if (unit === allowed[i]) {
                return polkit.Result.YES;
            }
        }
    }
});
